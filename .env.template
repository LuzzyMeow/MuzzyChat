# MuzzyChat 环境变量模板 — 复制为 .env 并填入实际值

# === 基础设施 ===
# 推荐方案：
#   PostgreSQL + pgvector → Neon (https://neon.tech) 免费 500MB，pgvector 内置
#   Redis → Upstash (https://upstash.com) 免费 10K 命令/日
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/muzzychat?sslmode=require
REDIS_URL=redis://default:password@host:port
PORT=3001
CORS_ORIGIN=http://localhost:5173

# === LLM 提供商 API 密钥（Phase 2 直连 LangChain SDK，不走网关） ===
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-your-anthropic-key
DEEPSEEK_API_KEY=sk-your-deepseek-key